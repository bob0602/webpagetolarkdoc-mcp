{
  "name": "webpage-content-reader-mcp",
  "version": "1.0.0",
  "description": "MCP server for high-fidelity webpage text, image, style, layout extraction and preview generation.",
  "type": "module",
  "bin": {
    "webpage-content-reader-mcp": "./dist/server.js",
    "webpage-reader-api": "./dist/api-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "dev:api": "tsx src/api-server.ts",
    "start:api": "node dist/api-server.js",
    "extract": "tsx src/cli.ts",
    "demo": "tsx demo-static-parse.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "playwright": "^1.54.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@larksuite/cli": "^1.0.29",
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
